<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🛹✨ SKATE CULT ✨🛹</title>
    <style>
        /* RESET Y RESPONSIVE BÁSICO */
        * {
            box-sizing: border-box;
        }

        /* FONDO Y ANIMACIÓN BASE */
        body {
            background-color: #000000;
            color: #00FF00; /* Verde fósforo */
            font-family: "Courier New", Courier, monospace;
            margin: 0;
            padding: 30px 10px;
            text-align: center;
            overflow-x: hidden;
            /* Efecto de parpadeo global CRT */
            animation: crt-flicker 0.15s infinite;
        }

        @keyframes crt-flicker {
            0% { opacity: 0.95; }
            50% { opacity: 0.99; }
            100% { opacity: 0.96; }
        }

        /* 📺 FILTRO CRT COMPLETAMENTE REALISTA 📺 */
        
        /* 1. Malla de píxeles y scanlines estáticas */
        body::before {
            content: " ";
            display: block;
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            right: 0;
            background: 
                linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), 
                linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
            z-index: 9998;
            background-size: 100% 2px, 3px 100%;
            pointer-events: none; /* Permite hacer clic a través del filtro */
        }

        /* 2. Sombra de curvatura del cristal (Viñeta) */
        body::after {
            content: " ";
            display: block;
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            right: 0;
            background: radial-gradient(circle, rgba(0,0,0,0) 50%, rgba(0,0,0,0.6) 100%);
            z-index: 9999;
            pointer-events: none;
        }

        /* 3. Línea de barrido que baja por la pantalla */
        .rolling-line {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 15vh;
            background: linear-gradient(to bottom, rgba(0,0,0,0) 0%, rgba(0, 255, 0, 0.05) 50%, rgba(0,0,0,0) 100%);
            z-index: 9997;
            opacity: 0.6;
            pointer-events: none;
            animation: scanline 8s linear infinite;
        }

        @keyframes scanline {
            0% { transform: translateY(-100vh); }
            100% { transform: translateY(100vh); }
        }

        /* CONTENEDOR PRINCIPAL */
        .container {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 800px;
            margin: 0 auto;
            border: 3px ridge #FF00FF; /* Magenta */
            padding: 15px;
            background-color: #0a0a0a;
            box-shadow: 0 0 15px rgba(255, 0, 255, 0.3), inset 0 0 20px rgba(0,0,0,0.8);
        }

        /* TÍTULOS CON ABERRACIÓN CROMÁTICA (RGB SPLIT) */
        h1, h2, h3 {
            color: #00FFFF; /* Cian */
            /* Efecto 3D magenta + Glitch RGB + Resplandor */
            text-shadow: 
                2px 2px #FF00FF, 
                -2px 0px 1px rgba(255,0,0,0.7), 
                2px 0px 1px rgba(0,0,255,0.7), 
                0 0 8px rgba(0, 255, 255, 0.5); 
            text-transform: uppercase;
            word-wrap: break-word;
        }

        /* TEXTOS NORMALES CON ABERRACIÓN CROMÁTICA Y RESPLANDOR */
        p, li {
            line-height: 1.6;
            font-size: 1rem;
            color: #00FF00;
            text-shadow: 
                -1px 0px 0px rgba(255,0,0,0.6), 
                1px 0px 0px rgba(0,0,255,0.6), 
                0px 0px 5px rgba(0, 255, 0, 0.5);
        }

        /* EFECTO PARPADEO DE TEXTO (BLINK) */
        .blink {
            animation: blinker 1.2s linear infinite;
            color: #FFFF00; /* Amarillo */
            text-shadow: 
                -1px 0px 0px rgba(255,0,0,0.6), 
                1px 0px 0px rgba(0,0,255,0.6),
                0 0 8px rgba(255, 255, 0, 0.6);
        }
        @keyframes blinker {
            50% { opacity: 0.2; }
        }

        /* LÍNEAS DIVISORIAS */
        hr {
            border: 0;
            border-top: 2px dashed #00FFFF; /* Cian */
            margin: 30px 0;
            box-shadow: 0 0 5px #00FFFF;
        }

        /* LISTAS SOMOS / NO SOMOS */
        .lists-container {
            display: flex;
            flex-direction: column;
            gap: 20px;
            border: 2px dotted #FFFF00; /* Amarillo */
            padding: 15px;
            margin: 20px 0;
        }
        
        .list-box {
            text-align: left;
            width: 100%;
        }

        ul {
            list-style-type: none;
            padding: 0;
            margin: 0;
        }
        li {
            margin-bottom: 10px;
        }

        .title-no { color: #FF0000 !important; text-shadow: 0 0 8px rgba(255, 0, 0, 0.6), -2px 0px 1px rgba(255,0,0,0.7), 2px 0px 1px rgba(0,0,255,0.7) !important; } 
        .title-si { color: #00FF00 !important; text-shadow: 0 0 8px rgba(0, 255, 0, 0.6), -2px 0px 1px rgba(255,0,0,0.7), 2px 0px 1px rgba(0,0,255,0.7) !important; } 

        /* ESTILOS DEL CHAT (xat.com) */
        .chat-box {
            margin: 40px auto 20px auto;
            width: 100%;
            position: relative;
            z-index: 20;
        }
        .chat-box iframe {
            max-width: 100%; 
            border: 2px solid #FF00FF; /* Magenta */
            box-shadow: 0 0 10px rgba(255, 0, 255, 0.5);
            background-color: #000;
        }

        /* FOOTER */
        .footer {
            margin-top: 40px;
            font-size: 0.9rem;
            color: #888;
            text-shadow: none;
        }

        /* MEDIA QUERIES */
        @media (min-width: 600px) {
            .container {
                padding: 30px;
            }
            .lists-container {
                flex-direction: row;
                justify-content: space-around;
            }
            p, li {
                font-size: 1.1rem;
            }
        }
    </style>
</head>
